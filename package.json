{
  "name": "procurewiz",
  "private": true,
  "version": "0.0.1",
  "description": "ProcureWiz monorepo for API, dashboard, extension, landing, and shared packages.",
  "license": "MIT",
  "packageManager": "pnpm@latest",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "start:api": "node apps/api/server.js"
  },
  "dependencies": {
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "turbo": "^2.10.1"
  }
}
